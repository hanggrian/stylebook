{
  "name": "@hanggrian/stylebook",
  "version": "0.3.0",
  "description": "Comprehensive linter aggregator for data and tooling formats",
  "keywords": [
    "css",
    "html",
    "json",
    "markdown",
    "md",
    "lint",
    "linter"
  ],
  "author": "Hendra Anggrian <hanggrian@proton.me> (http://hanggrian.com/)",
  "license": "Apache-2.0",
  "homepage": "https://github.com/hanggrian/stylebook#readme",
  "bugs": {
    "url": "https://github.com/hanggrian/stylebook/issues"
  },
  "repository": "hanggrian/stylebook",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "stylebook": "bin/main.js"
  },
  "files": [
    "bin",
    "dist",
    "resources"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint bin/ src/",
    "test": "vitest run",
    "cov": "vitest run --coverage --reporter=junit --outputFile=test-report.junit.xml"
  },
  "engines": {
    "node": ">=12.0.0"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "cli-progress": "^3.12.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/node": "25.9.1"
  },
  "optionalDependencies": {
    "@ibm/tekton-lint": "^1.2.0",
    "@prantlf/jsonlint": "^17.0.1",
    "@probelabs/maid": "^0.0.29",
    "@stylistic/stylelint-plugin": "^5.2.0",
    "asl-validator": "^4.0.0",
    "graphql-schema-linter": "^3.0.1",
    "htmlhint": "^1.9.2",
    "lockfile-lint-api": "^5.9.2",
    "markdown-it": "^14.2.0",
    "markdownlint": "^0.40.0"
  }
}
