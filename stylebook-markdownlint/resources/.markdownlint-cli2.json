{
  "customRules": [
    "stylebook-markdownlint"
  ],
  "config": {
    "code-block-style": {
      "style": "fenced"
    },
    "code-fence-style": {
      "style": "backtick"
    },
    "emphasis-style": {
      "style": "asterisk"
    },
    "first-line-heading": {
      "allow_preamble": true
    },
    "heading-style": {
      "style": "atx"
    },
    "hr-style": {
      "style": "---"
    },
    "line-length": {
      "code_blocks": false,
      "headings": false
    },
    "list-marker-space": false,
    "no-duplicate-heading": {
      "siblings_only": true
    },
    "no-inline-html": false,
    "ol-prefix": false,
    "strong-style": {
      "style": "asterisk"
    },
    "table-column-style": {
      "style": "compact"
    },
    "table-pipe-style": {
      "style": "leading_and_trailing"
    },
    "ul-style": {
      "style": "dash"
    }
  }
}
