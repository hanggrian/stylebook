{
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "pnpm -r build",
    "prelint": "pnpm -r lint",
    "lint": "stylebook .",
    "predocumentation": "rm -rf build/typedoc/",
    "documentation": "typedoc --entryPointStrategy packages --out build/typedoc/ stylebook/"
  },
  "engines": {
    "node": ">=12.0.0"
  },
  "packageManager": "pnpm@11.1.2",
  "dependencies": {
    "@hanggrian/stylebook": "workspace:*"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@stylistic/eslint-plugin": "5.10.0",
    "@stylistic/stylelint-plugin": "5.1.0",
    "@prantlf/jsonlint": "17.0.1",
    "@types/sinon": "21.0.1",
    "@vitest/coverage-v8": "4.1.5",
    "eslint": "10.0.1",
    "globals": "17.6.0",
    "htmlhint": "1.9.2",
    "jsdom": "29.1.1",
    "markdownlint-cli2": "0.22.1",
    "sinon": "22.0.0",
    "stylelint": "17.9.1",
    "stylelint-config-recommended": "18.0.0",
    "typedoc": "0.28.19",
    "typescript": "~5.9.3",
    "typescript-eslint": "8.59.1",
    "vite": "8.0.11",
    "vitest": "4.1.5",
    "vitest-dom": "0.1.1"
  }
}
