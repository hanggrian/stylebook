    "@stylistic/eslint-plugin": "5.10.0",
    "@stylistic/stylelint-plugin": "5.2.0",
    "@types/sinon": "21.0.1",
    "@vitest/coverage-v8": "4.1.7",
    "eslint": "10.4.0",
    "globals": "17.6.0",
    "jsdom": "29.1.1",
    "sinon": "22.0.0",
    "stylelint": "17.12.0",
    "stylelint-config-recommended": "18.0.0",
    "typedoc": "0.28.19",
    "typescript": "~6.0.3",
    "typescript-eslint": "8.59.4",
    "vite": "8.0.14",
    "vitest": "4.1.7",
    "vitest-dom": "0.1.1"
