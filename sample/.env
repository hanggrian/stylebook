# SpacedNameViolation — no leading spaces before names
SPACED_NAME_GOOD=hello

# IncorrectNameViolation — only A-Z, 0-9, underscore; no leading digit
CORRECT_NAME=1
NAME_WITH_NUMBERS_123=yes

# DuplicateNameViolation — each key appears exactly once
UNIQUE_KEY_A=foo
UNIQUE_KEY_B=bar

# RawNameViolation — every name must have = (even if value is empty)
EMPTY_VALUE=
KEY_WITH_VALUE=some_value

# ReservedNameViolation — avoid blacklisted names like DJANGO_ENV
APP_ENV=production
DJANGO_ENV_=staging

# SpacedAssignViolation — no spaces around the = sign
NO_SPACE_AROUND_EQUALS=value
ANOTHER_GOOD_KEY=

# SpacedValueViolation — no trailing spaces after values
NO_TRAILING_SPACE=cleanvalue

# QuotedValueViolation — no quotes wrapping values
UNQUOTED_VALUE=myvalue
DATABASE_URL=postgres://user:pass@localhost:5432/db

# InvalidEOLViolation — file uses LF (\n) line endings, not CRLF (\r\n)

# SpacedCommentViolation — no extra spaces inside comment text
#This comment has no leading spaces after the hash

# Real-world example
APP_NAME=myapp
DEBUG=false
PORT=8080
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=mydb
DATABASE_USER=admin
DATABASE_PASSWORD=supersecret
SECRET_KEY=changeme
ALLOWED_HOSTS=localhost,127.0.0.1
LOG_LEVEL=INFO
MAX_CONNECTIONS=100
CACHE_TTL=3600
FEATURE_FLAG_DARK_MODE=true
