pie
  %% PI-LABEL-REQUIRES-QUOTES: unquoted label
  %% PI-MISSING-COLON: missing colon separator
  %% PI-QUOTE-UNCLOSED: missing closing quote
  "label" : 10

  %% PI-MISSING-NUMBER: label with no numerical value
  %% PI-LABEL-ESCAPED-QUOTE: escaped quote inside label
  "test &quot; label" : 40

  %% PI-LABEL-DOUBLE-IN-DOUBLE: nested double quotes
  "hello &quot;world&quot;" : 50
